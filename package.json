{
  "productName": "Lux",
  "name": "lux",
  "description": "Lux Client",
  "author": "Lux Team <lux@pluginhub.de>",
  "version": "1.7.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dist-clean": "rimraf dist && rimraf release",
    "dist": "npm run dist-clean && npm run build && electron-builder --win --x64",
    "dist-win-all-arch": "npm run dist-clean && npm run build && electron-builder --win",
    "dist-mac": "npm run dist-clean && npm run build && electron-builder --mac",
    "dist-all": "npm run dist-clean && npm run build && electron-builder -wl",
    "dist-linux-deb": "npm run dist-clean && npm run build && electron-builder --linux deb"
  },
  "build": {
    "appId": "de.pluginhub.lux",
    "productName": "Lux",
    "compression": "normal",
    "icon": "resources/icon.png",
    "protocols": [
      {
        "name": "Lux Client",
        "schemes": [
          "luxclient"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "LuxClient",
        "repo": "LuxClient"
      }
    ],
    "files": [
      "dist",
      "electron",
      "backend",
      "resources",
      "public",
      ".env",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          ".env"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "executableName": "Lux",
      "icon": "resources/icon.icns",
      "extendInfo": {
        "CFBundleName": "Lux",
        "CFBundleDisplayName": "Lux",
        "CFBundleExecutable": "Lux",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "Lux Client",
            "CFBundleURLSchemes": [
              "luxclient"
            ]
          }
        ]
      },
      "category": "public.app-category.games",
      "artifactName": "${productName}-setup.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Game",
      "icon": "resources/icon.png",
      "executableName": "lux",
      "artifactName": "${productName}-setup.${ext}",
      "compression": "maximum"
    }
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csrf-csrf": "^4.0.3",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "framer-motion": "^12.40.0",
    "fs-extra": "^11.3.5",
    "i18next": "^26.3.1",
    "ipc-event-emitter": "^2.0.2",
    "js-yaml": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "mc-curseforge-api": "^2.2.3",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "nanoid": "^5.1.11",
    "pidtree": "^0.6.1",
    "pidusage": "^4.0.1",
    "prismarine-nbt": "^2.8.0",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-simple-code-editor": "^0.14.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "skinview3d": "^3.4.2",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "overrides": {
    "request": {
      "form-data": "^2.5.4",
      "qs": "^6.14.1",
      "tough-cookie": "^4.1.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.13.11",
    "@types/react": "^18.3.19",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "wait-on": "^9.0.10"
  }
}
